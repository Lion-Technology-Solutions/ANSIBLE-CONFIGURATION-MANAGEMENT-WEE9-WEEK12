# Sudoers file for admin users - automatically generated by Ansible user-management role
# DO NOT EDIT MANUALLY

{% set admin_users = users | selectattr('is_admin', 'equalto', true) | map(attribute='username') | list %}
{% if admin_users %}
# Admin users with full sudo privileges
{% for admin in admin_users %}
{{ admin }} ALL=(ALL) NOPASSWD:ALL
{% endfor %}
{% else %}
# No admin users configured
{% endif %}
