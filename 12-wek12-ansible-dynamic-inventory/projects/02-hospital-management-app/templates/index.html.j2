<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>LionTech Expo | Luxury Hotel Booking</title>
  <!-- Swiper CSS & JS (Slider Library) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  <!-- Font Awesome 6 (Free icons) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', sans-serif;
    }
    body {
      background: #f4f7fc;
      color: #1e2a3e;
    }
    /* Header */
    .navbar {
      background: #0f2b3d;
      color: white;
      padding: 1rem 2rem;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }
    .logo h1 {
      font-size: 1.8rem;
      letter-spacing: -0.5px;
    }
    .logo span {
      color: #f7b32b;
      font-weight: 800;
    }
    .currency-box {
      background: #1e4a6e;
      padding: 0.5rem 1rem;
      border-radius: 40px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 500;
    }
    .currency-box label {
      font-size: 0.9rem;
    }
    #currencySelector {
      background: white;
      border: none;
      padding: 0.4rem 0.8rem;
      border-radius: 30px;
      font-weight: bold;
      cursor: pointer;
      outline: none;
    }
    /* Container */
    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 1.5rem;
    }
    /* Section titles */
    .section-title {
      font-size: 2rem;
      font-weight: 700;
      margin: 2rem 0 1rem 0;
      border-left: 6px solid #f7b32b;
      padding-left: 1rem;
      color: #0f2b3d;
    }
    /* Swiper wrapper custom */
    .swiper {
      padding: 1rem 0 2.5rem 0;
      overflow: hidden;
    }
    .swiper-slide {
      background: white;
      border-radius: 24px;
      box-shadow: 0 12px 28px rgba(0,0,0,0.08);
      transition: transform 0.2s;
      overflow: hidden;
    }
    .room-card, .deal-card, .gallery-card {
      border-radius: 24px;
      background: white;
    }
    .card-img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      border-top-left-radius: 24px;
      border-top-right-radius: 24px;
    }
    .card-info {
      padding: 1.2rem;
    }
    .card-title {
      font-size: 1.4rem;
      font-weight: 700;
    }
    .card-desc {
      color: #4a627a;
      margin: 0.5rem 0;
      font-size: 0.9rem;
    }
    .price-tag {
      font-weight: 800;
      font-size: 1.3rem;
      color: #0f2b3d;
      margin-top: 8px;
    }
    .btn-apply {
      background: #f7b32b;
      border: none;
      margin-top: 12px;
      padding: 8px 14px;
      border-radius: 40px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.2s;
      width: 100%;
      font-size: 0.9rem;
    }
    .btn-apply:hover {
      background: #e09d1b;
      transform: scale(0.98);
    }
    /* Booking panel */
    .booking-panel {
      background: white;
      border-radius: 32px;
      padding: 2rem;
      margin: 2rem 0;
      box-shadow: 0 20px 35px rgba(0,0,0,0.05);
    }
    .booking-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-bottom: 1.8rem;
    }
    .input-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .input-group label {
      font-weight: 600;
      color: #2c3e50;
    }
    .input-group input, .input-group select {
      padding: 12px 14px;
      border-radius: 28px;
      border: 1px solid #cbd5e1;
      font-size: 1rem;
      background: #fefefe;
      transition: 0.2s;
    }
    .checkbox-group {
      flex-direction: row;
      align-items: center;
      gap: 12px;
    }
    .checkbox-group input {
      width: 20px;
      height: 20px;
    }
    .total-box {
      background: #eef2f5;
      padding: 1rem 1.5rem;
      border-radius: 50px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      margin: 1.5rem 0;
    }
    .total-amount {
      font-size: 1.8rem;
      font-weight: 800;
      color: #0f2b3d;
    }
    .btn-book {
      background: #1e6f3f;
      color: white;
      border: none;
      padding: 1rem 2rem;
      font-size: 1.2rem;
      font-weight: bold;
      border-radius: 60px;
      width: 100%;
      cursor: pointer;
      transition: background 0.2s;
      box-shadow: 0 5px 10px rgba(0,0,0,0.1);
    }
    .btn-book:hover {
      background: #0f542f;
    }
    .deal-active {
      background: #d9f0e1;
      padding: 8px 15px;
      border-radius: 40px;
      font-size: 0.9rem;
      display: inline-block;
    }
    footer {
      background: #0f2b3d;
      color: #bbb;
      text-align: center;
      padding: 1.8rem;
      margin-top: 2rem;
      font-size: 0.9rem;
    }
    /* Modal (fake payment gateway) */
    .modal {
      display: none;
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0,0,0,0.6);
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }
    .modal-content {
      background: white;
      max-width: 480px;
      width: 90%;
      border-radius: 32px;
      padding: 2rem;
      position: relative;
      animation: fadeInUp 0.3s;
    }
    @keyframes fadeInUp {
      from { transform: translateY(30px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
    .modal-content h3 {
      font-size: 1.8rem;
      margin-bottom: 1rem;
    }
    .fake-input {
      width: 100%;
      padding: 12px;
      margin: 8px 0;
      border-radius: 28px;
      border: 1px solid #ccc;
    }
    .close-modal {
      position: absolute;
      right: 20px;
      top: 15px;
      font-size: 1.8rem;
      cursor: pointer;
    }
    @media (max-width: 720px) {
      .navbar {
        flex-direction: column;
        gap: 12px;
      }
      .section-title {
        font-size: 1.6rem;
      }
    }
    .pickup-badge {
      background: #f0f3f8;
      padding: 5px 12px;
      border-radius: 20px;
    }
    .swiper-button-next, .swiper-button-prev {
      color: #f7b32b;
      background: rgba(255,255,255,0.8);
      width: 40px;
      height: 40px;
      border-radius: 50%;
    }
    .swiper-button-next:after, .swiper-button-prev:after {
      font-size: 1.2rem;
      font-weight: bold;
    }
  </style>
</head>
<body>

<div class="navbar">
  <div class="logo">
    <h1>🦁 LIONTECH <span>EXPO</span> HOTEL</h1>
    <small style="font-size: 0.7rem;">Luxury & Comfort Redefined</small>
  </div>
  <div class="currency-box">
    <i class="fas fa-globe"></i>
    <label>Currency Converter</label>
    <select id="currencySelector">
      <option value="USD">USD ($)</option>
      <option value="EUR">EUR (€)</option>
      <option value="GBP">GBP (£)</option>
      <option value="INR">INR (₹)</option>
    </select>
  </div>
</div>

<div class="container">
  
  <!-- GALLERY SLIDER -->
  <div class="section-title"><i class="fas fa-images"></i> Hotel Gallery</div>
  <div class="swiper gallerySwiper">
    <div class="swiper-wrapper">
      <div class="swiper-slide"><img class="card-img" src="https://picsum.photos/id/104/800/500" alt="Lobby"></div>
      <div class="swiper-slide"><img class="card-img" src="https://picsum.photos/id/164/800/500" alt="Pool"></div>
      <div class="swiper-slide"><img class="card-img" src="https://picsum.photos/id/29/800/500" alt="Restaurant"></div>
      <div class="swiper-slide"><img class="card-img" src="https://picsum.photos/id/42/800/500" alt="Spa"></div>
      <div class="swiper-slide"><img class="card-img" src="https://picsum.photos/id/15/800/500" alt="Beach View"></div>
    </div>
    <div class="swiper-button-next"></div>
    <div class="swiper-button-prev"></div>
    <div class="swiper-pagination"></div>
  </div>

  <!-- HOTEL ROOMS SLIDER -->
  <div class="section-title"><i class="fas fa-bed"></i> Premium Rooms</div>
  <div class="swiper roomsSwiper">
    <div class="swiper-wrapper" id="roomsSliderWrapper"></div>
    <div class="swiper-button-next"></div>
    <div class="swiper-button-prev"></div>
    <div class="swiper-pagination"></div>
  </div>

  <!-- DEALS SLIDER -->
  <div class="section-title"><i class="fas fa-tags"></i> Hot Deals & Offers</div>
  <div class="swiper dealsSwiper">
    <div class="swiper-wrapper" id="dealsSliderWrapper"></div>
    <div class="swiper-button-next"></div>
    <div class="swiper-button-prev"></div>
    <div class="swiper-pagination"></div>
  </div>

  <!-- BOOKING RESERVATION + PICKUP + FAKE GATEWAY -->
  <div class="booking-panel">
    <h2 style="margin-bottom: 1.5rem;"><i class="fas fa-calendar-check"></i> Reserve Your Stay</h2>
    <div class="booking-grid">
      <div class="input-group">
        <label><i class="fas fa-calendar-alt"></i> Check-in</label>
        <input type="date" id="checkinDate" value="2026-06-01">
      </div>
      <div class="input-group">
        <label><i class="fas fa-calendar-alt"></i> Check-out</label>
        <input type="date" id="checkoutDate" value="2026-06-04">
      </div>
      <div class="input-group">
        <label><i class="fas fa-users"></i> Guests</label>
        <input type="number" id="guests" min="1" max="6" value="2">
      </div>
      <div class="input-group">
        <label><i class="fas fa-door-open"></i> Select Room</label>
        <select id="roomSelect"></select>
      </div>
      <div class="input-group checkbox-group">
        <input type="checkbox" id="pickupService">
        <label><i class="fas fa-shuttle-van"></i> Airport Pick-up Service (+$25 / booking)</label>
      </div>
      <div class="input-group">
        <label><i class="fas fa-gift"></i> Active Deal</label>
        <div id="activeDealDisplay" class="deal-active">No deal applied</div>
      </div>
    </div>

    <div class="total-box">
      <span><strong>Total Amount</strong> (incl. tax & service)</span>
      <span class="total-amount" id="totalAmount">$0.00</span>
    </div>

    <button class="btn-book" id="proceedPaymentBtn"><i class="fas fa-credit-card"></i> Proceed to Fake Payment</button>
    <p style="margin-top: 12px; font-size: 0.75rem; text-align: center;">*Fake payment gateway - test booking simulation</p>
  </div>
</div>

<footer>
  <p>© 2025 LionTech Expo — Redefining Hospitality</p>
  <p><i class="fas fa-code"></i> Developed by LionTech Students | Full-stack Hotel Booking Experience</p>
</footer>

<!-- FAKE PAYMENT MODAL -->
<div id="paymentModal" class="modal">
  <div class="modal-content">
    <span class="close-modal" id="closeModalBtn">&times;</span>
    <h3><i class="fas fa-lock"></i> Secure Payment Gateway</h3>
    <p style="margin-bottom: 1rem;">🔐 Fake transaction | Demo only</p>
    <label>Cardholder Name</label>
    <input type="text" class="fake-input" id="cardName" placeholder="John Doe">
    <label>Card Number</label>
    <input type="text" class="fake-input" id="cardNumber" placeholder="4242 4242 4242 4242">
    <div style="display: flex; gap: 12px;">
      <div><label>Expiry</label><input type="text" class="fake-input" placeholder="MM/YY"></div>
      <div><label>CVC</label><input type="text" class="fake-input" placeholder="123"></div>
    </div>
    <button id="confirmPaymentBtn" style="background:#1e6f3f; color:white; border:none; width:100%; padding: 14px; border-radius: 40px; font-weight: bold; margin-top: 20px; cursor:pointer;">Pay Now (Fake)</button>
  </div>
</div>

<script>
  // ---------- HOTEL DATA ----------
  const roomsData = [
    { id: 1, name: "🌿 Standard Oasis", desc: "Cozy room with city skyline, free Wi-Fi", priceUSD: 120, image: "https://picsum.photos/id/163/500/350" },
    { id: 2, name: "✨ Deluxe Executive", desc: "Spacious with sea view & VIP amenities", priceUSD: 210, image: "https://picsum.photos/id/177/500/350" },
    { id: 3, name: "👑 Presidential Suite", desc: "Private terrace + jacuzzi, butler service", priceUSD: 420, image: "https://picsum.photos/id/107/500/350" }
  ];

  const dealsData = [
    { id: 1, title: "🏷️ SUMMER BREEZE", discount: 15, description: "15% off on stays over 2 nights", image: "https://picsum.photos/id/26/500/350" },
    { id: 2, title: "💎 WEEKEND ESCAPE", discount: 10, description: "10% off + complimentary breakfast", image: "https://picsum.photos/id/30/500/350" },
    { id: 3, title: "🌟 LOYALTY MEMBER", discount: 20, description: "20% exclusive discount for members", image: "https://picsum.photos/id/58/500/350" },
    { id: 4, title: "✈️ EARLY BIRD", discount: 12, description: "12% off book 7+ days ahead", image: "https://picsum.photos/id/96/500/350" }
  ];

  // Exchange rates (based on USD)
  const rates = { USD: 1, EUR: 0.92, GBP: 0.78, INR: 83.5 };
  let currentCurrency = "USD";
  let selectedDeal = null;        // null or deal object
  let selectedRoomId = roomsData[0].id;

  // DOM elements
  const roomsWrapper = document.getElementById("roomsSliderWrapper");
  const dealsWrapper = document.getElementById("dealsSliderWrapper");
  const roomSelect = document.getElementById("roomSelect");
  const currencySelector = document.getElementById("currencySelector");
  const totalSpan = document.getElementById("totalAmount");
  const activeDealDisplay = document.getElementById("activeDealDisplay");
  const checkinInput = document.getElementById("checkinDate");
  const checkoutInput = document.getElementById("checkoutDate");
  const guestsInput = document.getElementById("guests");
  const pickupCheck = document.getElementById("pickupService");
  
  let roomsSwiperInstance = null;
  let dealsSwiperInstance = null;
  let gallerySwiperInstance = null;

  // Helper functions
  function formatCurrency(amountUSD) {
    let converted = amountUSD * rates[currentCurrency];
    const symbol = currentCurrency === "USD" ? "$" : currentCurrency === "EUR" ? "€" : currentCurrency === "GBP" ? "£" : "₹";
    return `${symbol}${converted.toFixed(2)}`;
  }

  // get room by id
  function getRoomById(id) {
    return roomsData.find(r => r.id == id);
  }

  // compute nights between dates
  function getNights() {
    const start = new Date(checkinInput.value);
    const end = new Date(checkoutInput.value);
    if (isNaN(start) || isNaN(end) || end <= start) return 1;
    const diffTime = Math.abs(end - start);
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    return diffDays > 0 ? diffDays : 1;
  }

  // Calculate total in USD, then format & display
  function updateTotalAndDisplay() {
    const room = getRoomById(selectedRoomId);
    if (!room) return;
    const nights = getNights();
    let baseRoomTotalUSD = room.priceUSD * nights;
    let pickupCostUSD = pickupCheck.checked ? 25 : 0;
    let subtotalUSD = baseRoomTotalUSD + pickupCostUSD;
    let discountPercent = selectedDeal ? selectedDeal.discount : 0;
    let discountedTotalUSD = subtotalUSD * (1 - discountPercent / 100);
    const finalUSD = discountedTotalUSD;
    totalSpan.innerText = formatCurrency(finalUSD);
    return { finalUSD, room, nights, pickupCostUSD, discountPercent };
  }

  // Update displayed price for each room card (per night in current currency)
  function updateRoomCardsCurrency() {
    const roomPriceSpans = document.querySelectorAll(".room-price-value");
    if (roomPriceSpans.length) {
      roomsData.forEach((room, idx) => {
        if (roomPriceSpans[idx]) {
          const perNightUSD = room.priceUSD;
          const converted = perNightUSD * rates[currentCurrency];
          const symbol = currentCurrency === "USD" ? "$" : currentCurrency === "EUR" ? "€" : currentCurrency === "GBP" ? "£" : "₹";
          roomPriceSpans[idx].innerText = `${symbol}${converted.toFixed(2)} / night`;
        }
      });
    }
    // Also update room select dropdown display (price part)
    updateRoomSelectDropdown();
    updateTotalAndDisplay();
  }

  // populate room select dropdown with dynamic currency text
  function updateRoomSelectDropdown() {
    roomSelect.innerHTML = "";
    roomsData.forEach(room => {
      const option = document.createElement("option");
      option.value = room.id;
      const convertedPrice = room.priceUSD * rates[currentCurrency];
      const symbol = currentCurrency === "USD" ? "$" : currentCurrency === "EUR" ? "€" : currentCurrency === "GBP" ? "£" : "₹";
      option.innerText = `${room.name} - ${symbol}${convertedPrice.toFixed(2)} / night`;
      if (room.id == selectedRoomId) option.selected = true;
      roomSelect.appendChild(option);
    });
  }

  // Render rooms slider (dynamic)
  function renderRoomsSlider() {
    roomsWrapper.innerHTML = "";
    roomsData.forEach((room, index) => {
      const convertedPrice = room.priceUSD * rates[currentCurrency];
      const symbol = currentCurrency === "USD" ? "$" : currentCurrency === "EUR" ? "€" : currentCurrency === "GBP" ? "£" : "₹";
      const slideDiv = document.createElement("div");
      slideDiv.className = "swiper-slide";
      slideDiv.innerHTML = `
        <div class="room-card">
          <img class="card-img" src="${room.image}" alt="${room.name}">
          <div class="card-info">
            <div class="card-title">${room.name}</div>
            <div class="card-desc">${room.desc}</div>
            <div class="price-tag"><span class="room-price-value">${symbol}${convertedPrice.toFixed(2)} / night</span></div>
            <button class="btn-apply select-room-btn" data-room-id="${room.id}">Select this Room</button>
          </div>
        </div>
      `;
      roomsWrapper.appendChild(slideDiv);
    });
    // attach event listeners to each 'select room' button after render
    document.querySelectorAll(".select-room-btn").forEach(btn => {
      btn.addEventListener("click", (e) => {
        const roomId = parseInt(btn.getAttribute("data-room-id"));
        selectedRoomId = roomId;
        updateRoomSelectDropdown();
        updateTotalAndDisplay();
        // visual feedback
        alert(`✨ Room updated to: ${getRoomById(roomId).name}`);
      });
    });
    if (roomsSwiperInstance) roomsSwiperInstance.destroy(true, true);
    roomsSwiperInstance = new Swiper('.roomsSwiper', {
      slidesPerView: 1,
      spaceBetween: 20,
      navigation: { nextEl: '.roomsSwiper .swiper-button-next', prevEl: '.roomsSwiper .swiper-button-prev' },
      pagination: { el: '.roomsSwiper .swiper-pagination', clickable: true },
      breakpoints: { 640: { slidesPerView: 2 }, 1024: { slidesPerView: 3 } }
    });
  }

  // Render deals slider
  function renderDealsSlider() {
    dealsWrapper.innerHTML = "";
    dealsData.forEach(deal => {
      const slideDiv = document.createElement("div");
      slideDiv.className = "swiper-slide";
      slideDiv.innerHTML = `
        <div class="deal-card">
          <img class="card-img" src="${deal.image}" alt="${deal.title}">
          <div class="card-info">
            <div class="card-title">${deal.title}</div>
            <div class="card-desc">${deal.description}</div>
            <div class="price-tag" style="font-size:1rem;">🔥 ${deal.discount}% OFF</div>
            <button class="btn-apply apply-deal-btn" data-deal-id="${deal.id}" data-discount="${deal.discount}" data-title="${deal.title}">Apply this Deal</button>
          </div>
        </div>
      `;
      dealsWrapper.appendChild(slideDiv);
    });
    document.querySelectorAll(".apply-deal-btn").forEach(btn => {
      btn.addEventListener("click", (e) => {
        const dealId = parseInt(btn.getAttribute("data-deal-id"));
        const discount = parseInt(btn.getAttribute("data-discount"));
        const title = btn.getAttribute("data-title");
        selectedDeal = dealsData.find(d => d.id === dealId);
        activeDealDisplay.innerHTML = `✅ Active: ${title} (${discount}% off) &nbsp; <span style="cursor:pointer; color:#c00;" id="removeDealBtn">✖ Remove</span>`;
        const removeBtn = document.getElementById("removeDealBtn");
        if(removeBtn) removeBtn.onclick = () => { selectedDeal = null; activeDealDisplay.innerHTML = "No deal applied"; updateTotalAndDisplay(); renderDealsSlider(); };
        updateTotalAndDisplay();
        alert(`Deal "${title}" applied! ${discount}% discount will reflect.`);
      });
    });
    if (dealsSwiperInstance) dealsSwiperInstance.destroy(true, true);
    dealsSwiperInstance = new Swiper('.dealsSwiper', {
      slidesPerView: 1,
      spaceBetween: 20,
      navigation: { nextEl: '.dealsSwiper .swiper-button-next', prevEl: '.dealsSwiper .swiper-button-prev' },
      pagination: { el: '.dealsSwiper .swiper-pagination', clickable: true },
      breakpoints: { 640: { slidesPerView: 2 }, 1024: { slidesPerView: 3 } }
    });
  }

  // Gallery Swiper (static content)
  function initGallerySwiper() {
    if(gallerySwiperInstance) gallerySwiperInstance.destroy(true, true);
    gallerySwiperInstance = new Swiper('.gallerySwiper', {
      slidesPerView: 1,
      spaceBetween: 15,
      navigation: { nextEl: '.gallerySwiper .swiper-button-next', prevEl: '.gallerySwiper .swiper-button-prev' },
      pagination: { el: '.gallerySwiper .swiper-pagination', clickable: true },
      loop: true,
      autoplay: { delay: 3000, disableOnInteraction: false },
      breakpoints: { 768: { slidesPerView: 2 }, 1024: { slidesPerView: 3 } }
    });
  }

  // Event listeners for booking changes
  function bindBookingEvents() {
    const updateAll = () => updateTotalAndDisplay();
    checkinInput.addEventListener("change", updateAll);
    checkoutInput.addEventListener("change", updateAll);
    guestsInput.addEventListener("change", updateAll);
    pickupCheck.addEventListener("change", updateAll);
    roomSelect.addEventListener("change", (e) => {
      selectedRoomId = parseInt(e.target.value);
      updateTotalAndDisplay();
    });
  }

  // Fake payment gateway modal logic
  const modal = document.getElementById("paymentModal");
  const proceedBtn = document.getElementById("proceedPaymentBtn");
  const closeModal = document.getElementById("closeModalBtn");
  const confirmPayBtn = document.getElementById("confirmPaymentBtn");

  function openPaymentModal() {
    // validation check: must have valid dates, room selected
    const nights = getNights();
    if (nights < 1) {
      alert("❌ Please select valid check-out date after check-in.");
      return false;
    }
    if (!getRoomById(selectedRoomId)) {
      alert("Please select a room.");
      return false;
    }
    modal.style.display = "flex";
    return true;
  }

  proceedBtn.addEventListener("click", () => {
    openPaymentModal();
  });

  closeModal.addEventListener("click", () => {
    modal.style.display = "none";
  });
  window.addEventListener("click", (e) => {
    if (e.target === modal) modal.style.display = "none";
  });

  confirmPayBtn.addEventListener("click", () => {
    // fake payment simulation
    const cardName = document.getElementById("cardName").value.trim();
    if(cardName === "") {
      alert("Please enter cardholder name (fake demo)");
      return;
    }
    const room = getRoomById(selectedRoomId);
    const nights = getNights();
    const totalUSDdata = updateTotalAndDisplay();
    const bookingId = "LNT" + Math.floor(Math.random() * 100000);
    // reservation summary
    const pickupText = pickupCheck.checked ? "✅ Airport Pick-up included" : "No pick-up";
    const dealText = selectedDeal ? `Deal: ${selectedDeal.title} (${selectedDeal.discount}% off)` : "No deal applied";
    alert(`🎉 FAKE PAYMENT SUCCESSFUL! 🎉\nReservation ID: ${bookingId}\nHotel: LionTech Expo\nRoom: ${room.name}\nNights: ${nights}\nTotal paid: ${totalSpan.innerText}\n${pickupText}\n${dealText}\nThank you for booking with LionTech Students! A confirmation email will be sent (demo).`);
    modal.style.display = "none";
    // optional reset form? no, but users can new booking.
    // Reset deal? Not needed, but keep for new booking.
  });

  // Currency converter handler
  function handleCurrencyChange() {
    currentCurrency = currencySelector.value;
    updateRoomCardsCurrency();    // updates price per night on room cards
    updateRoomSelectDropdown();
    updateTotalAndDisplay();
  }

  // remove any preexisting deal remove icon functionality when re-render deals
  // Also initializations
  function init() {
    renderRoomsSlider();
    renderDealsSlider();
    initGallerySwiper();
    updateRoomSelectDropdown();
    bindBookingEvents();
    currencySelector.addEventListener("change", handleCurrencyChange);
    // initial total display
    updateTotalAndDisplay();
    // add event for manual pickup display effect
  }

  // also watch for date/room changes
  document.addEventListener("DOMContentLoaded", () => {
    init();
    // additional: when apply deal we update, deal removal update inside
  });
</script>
