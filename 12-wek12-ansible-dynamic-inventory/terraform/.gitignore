# -----------------------------------
# Terraform Core Files
# -----------------------------------

# Local .terraform directories
.terraform/

# Terraform state files (VERY SENSITIVE)
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI config files
.terraformrc
terraform.rc

# -----------------------------------
# Sensitive Variables / Secrets
# -----------------------------------

# Variable files (can contain secrets)
*.tfvars
*.tfvars.json

# Example: keep sample files
!*.example.tfvars

# -----------------------------------
# Plan files
# -----------------------------------
*.tfplan
*.plan

# -----------------------------------
# Lock file (OPTIONAL STRATEGY)
# -----------------------------------
# Uncomment ONLY if you don’t want to commit lock file
# .terraform.lock.hcl

# Recommended: keep it committed for consistency
# (so leave it OUT of ignore unless needed)

# -----------------------------------
# Logs
# -----------------------------------
*.log

# -----------------------------------
# OS / Editor Files
# -----------------------------------

# macOS
.DS_Store

# Windows
Thumbs.db

# Linux temp
*~

# VS Code
.vscode/

# IntelliJ / JetBrains
.idea/

# -----------------------------------
# Python / Ansible (if combined project)
# -----------------------------------

# Python virtual environments
venv/
.env/
__pycache__/
*.pyc

# Ansible temp files
*.retry

# -----------------------------------
# AWS / Credentials (VERY IMPORTANT)
# -----------------------------------

# Never commit credentials
*.pem
*.key
*.pub

# AWS credentials files
.aws/